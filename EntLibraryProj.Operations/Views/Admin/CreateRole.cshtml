@model EntLibraryProj.Entities.CreateRoleViewModel
@*
    This page allows the create of new roles in the AspNetRoles table. Requires entry of a role name
*@
@{
}
@using (Html.BeginForm("CreateRole", "Admin"))
{
    @Html.ValidationSummary("", new { @class = "text-danger" })

    @Html.Label("Role Name: ")
    @Html.TextBoxFor(x => x.RoleName)
    @Html.ValidationMessageFor(x => x.RoleName)
    <div />
    <input type="submit" value="Create Role" />

}